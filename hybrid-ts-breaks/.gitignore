# ============================================================
# R AND RSTUDIO
# ============================================================

.Rhistory
.RData
.Ruserdata
.Rproj.user/
.Rproj.user
.httr-oauth

# ============================================================
# RENV ENVIRONMENT CONTROL
# Keep renv.lock, renv/activate.R, and renv/settings.json.
# Do not commit the local package library.
# ============================================================

renv/library/
renv/staging/
renv/sandbox/

# ============================================================
# QUARTO GENERATED FILES
# Keep source files such as report.qmd and _quarto.yml.
# Do not commit rendered or cached build products.
# ============================================================

.quarto/
_quarto/
_freeze/
**/*.quarto_ipynb

# Rendered Quarto outputs
outputs/rendered/
*.html
*.docx
*.pdf

# ============================================================
# OUTPUTS GENERATED BY ANALYSIS
# Keep the folders locally, but do not commit generated results.
# ============================================================

outputs/figures/*
!outputs/figures/.gitkeep

outputs/tables/*
!outputs/tables/.gitkeep

outputs/models/*
!outputs/models/.gitkeep

logs/*
!logs/.gitkeep

# ============================================================
# DATA POLICY
# Raw data should not be committed unless source licence permits.
# Processed and simulated data can become large, so exclude by default.
# Keep only .gitkeep files so folders remain visible in GitHub.
# ============================================================

data/raw/*
!data/raw/.gitkeep

data/processed/*
!data/processed/.gitkeep

data/simulated/*
!data/simulated/.gitkeep

# ============================================================
# TEMPORARY LATEX / PDF / KNITR FILES
# ============================================================

*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.log
*.lot
*.out
*.run.xml
*.synctex.gz
*.toc
*.xdv

# ============================================================
# TEMPORARY AND CACHE FILES
# ============================================================

*_cache/
cache/
knitr-cache/
*.tmp
*.bak
*.swp

# ============================================================
# OPERATING SYSTEM FILES
# ============================================================

.DS_Store
Thumbs.db
desktop.ini